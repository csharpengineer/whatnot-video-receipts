{
  "manifest_version": 3,
  "name": "Whatnot Video Receipt",
  "version": "1.0",
  "description": "Watch your video receipt (livestream recording) on Whatnot order pages.",
  "permissions": ["downloads"],
  "background": { "service_worker": "background.js" },
  "host_permissions": [
    "https://www.whatnot.com/*",
    "https://api.whatnot.com/*",
    "https://s3ntry.whatnot.com/*"
  ],
  "content_scripts": [
    {
      "matches": ["https://www.whatnot.com/order/*"],
      "js": ["early_content.js"],
      "world": "MAIN",
      "run_at": "document_start"
    },
    {
      "matches": ["https://www.whatnot.com/order/*"],
      "js": ["content.js"],
      "css": ["content.css"],
      "run_at": "document_idle"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["injected.js", "hls.min.js", "background.js"],
      "matches": ["https://www.whatnot.com/*"]
    }
  ],
  "icons": {
    "128": "icon128.png"
  }
}
