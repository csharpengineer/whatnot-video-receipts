{
  "manifest_version": 3,
  "name": "Whatnot Video Receipt",
  "version": "1.0.1",
  "description": "Watch video receipts, track shipments, and browse purchase history with advanced filtering — right on Whatnot.",
  "permissions": ["downloads", "storage"],
  "background": { "service_worker": "background.js" },
  "host_permissions": [
    "https://www.whatnot.com/*",
    "https://api.whatnot.com/*",
    "https://s3ntry.whatnot.com/*",
    "https://whatnot-shipping.s3.amazonaws.com/*"
  ],
  "content_scripts": [
    {
      "matches": ["https://www.whatnot.com/*"],
      "js": ["early_content.js"],
      "world": "MAIN",
      "run_at": "document_start"
    },
    {
      "matches": ["https://www.whatnot.com/*"],
      "js": ["content.js"],
      "css": ["content.css"],
      "run_at": "document_idle"
    },
    {
      "matches": ["https://www.whatnot.com/*"],
      "js": ["chart.umd.min.js", "advanced.js"],
      "run_at": "document_idle"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["injected.js", "hls.min.js", "background.js", "chart.umd.min.js"],
      "matches": ["https://www.whatnot.com/*"]
    }
  ],
  "icons": {
    "16": "icon16.png",
    "48": "icon48.png",
    "128": "icon128.png"
  }
}
